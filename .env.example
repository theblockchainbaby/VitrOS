# Database (PostgreSQL via Neon)
DATABASE_URL="postgresql://user:password@host/vitros?sslmode=require"

# NextAuth - generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Cloudinary (optional - for photo uploads)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# Resend transactional email (welcome + password reset). Required for those to send.
# Use a Resend key scoped to transactional/account mail ONLY (not cold outreach).
# Domain vitroslabs.com must be verified in Resend (DKIM + SPF + DMARC) or sends fail.
RESEND_API_KEY=""
# Optional sender overrides. Defaults: from "VitrOS <noreply@vitroslabs.com>",
# reply-to support@vitroslabs.com. Any override must be on a Resend-verified domain.
# EMAIL_FROM="VitrOS <noreply@vitroslabs.com>"
# EMAIL_REPLY_TO="support@vitroslabs.com"

# Cold outreach (DORMANT - leave unset to keep it off). Separate key on a separate
# domain (outreach.vitroslabs.com) so cold sending can never touch the transactional key.
# OUTREACH_RESEND_API_KEY=""
